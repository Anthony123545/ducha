# 页面标题
VUE_APP_TITLE=智能督查管理平台

# 开发环境配置
ENV=development

# 智能督察管理平台/开发环境
VUE_APP_BASE_API=/dev-api

# 路由懒加载
VUE_CLI_BABEL_TRANSPILE_MODULES=true

# WebSocket 地址（开发环境）
VUE_APP_WS_URL=ws://localhost:8090/websocket

# 访客拍照地址
VUE_APP_VISITOR_URL=https://blog.csdn.net/weixin_43957384/article/details/131111544
