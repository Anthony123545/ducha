<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.supervision.web.Hikvision.carDoor.web.mapper.NameListMapper">

    <resultMap id="NameListResultMap" type="com.supervision.web.Hikvision.carDoor.web.entity.NameList">
        <id column="id" property="id"/>
        <result column="device_id" property="deviceId"/>
        <result column="license_plate" property="licensePlate"/>
        <result column="type" property="type"/>
        <result column="access_start_time" property="accessStartTime"/>
        <result column="access_end_time" property="accessEndTime"/>
        <result column="channel" property="channel"/>
        <result column="plate_type" property="plateType"/>
        <result column="plate_color" property="plateColor"/>
        <result column="card_no" property="cardNo"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 查询列表 -->
    <select id="searchByCondition" resultMap="NameListResultMap">
        SELECT *
        FROM new_name_list
        <where>
            <if test="deviceId != null and deviceId != ''">
                AND device_id = #{deviceId}
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
            <if test="licensePlate != null and licensePlate != ''">
                AND license_plate LIKE CONCAT('%', #{licensePlate}, '%')
            </if>
        </where>
        ORDER BY id ASC
    </select>

    <!-- 批量查询 -->
    <select id="getByIds" resultMap="NameListResultMap" parameterType="java.util.List">
        SELECT *
        FROM new_name_list
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="getById" resultMap="NameListResultMap" parameterType="long">
        SELECT *
        FROM new_name_list
        WHERE id = #{id}
    </select>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.supervision.web.Hikvision.carDoor.web.entity.NameList">
        INSERT INTO new_name_list
            (
             device_id,
             license_plate,
             type,
             access_start_time,
             access_end_time,
             channel,
             plate_type,
             plate_color,
             card_No
             )
        VALUES
            (
            #{deviceId},
            #{licensePlate},
            #{type},
            #{accessStartTime},
            #{accessEndTime},
            #{channel},
            #{plateType},
            #{plateColor},
            #{cardNo}
            )
    </insert>

    <!-- 更新 -->
    <update id="update" parameterType="com.supervision.web.Hikvision.carDoor.web.entity.NameList">
        UPDATE new_name_list
        SET
            device_id = #{deviceId},
            license_plate = #{licensePlate},
            type = #{type},
            access_start_time = #{accessStartTime},
            access_end_time = #{accessEndTime},
            channel = #{channel},
            plate_type = #{plateType},
            plate_color = #{plateColor},
            card_No = #{cardNo}
        WHERE id = #{id}
    </update>

    <!-- 单个删除 -->
    <delete id="delete" parameterType="long">
        DELETE FROM new_name_list WHERE id = #{id}
    </delete>

    <!-- 批量删除 -->
    <delete id="batchDelete" parameterType="java.util.List">
        DELETE FROM new_name_list
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 校验重复 -->
    <select id="exists" resultType="int">
        SELECT COUNT(*) FROM new_name_list
        WHERE device_id = #{deviceId} AND license_plate = #{licensePlate} AND type = #{type}
    </select>

    <!-- 校验重复（排除自己） -->
    <select id="existsExcludeId" resultType="int">
        SELECT COUNT(*)
        FROM new_name_list
        WHERE device_id = #{deviceId}
        AND license_plate = #{licensePlate}
        AND type = #{type}
        AND id &lt;&gt; #{id}  <!-- 使用 &lt;>&gt; 代替 <> -->
    </select>

</mapper>
