<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.supervision.web.Hikvision.carDoor.web.mapper.VehicleAccessRecordMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.supervision.web.Hikvision.carDoor.web.entity.VehicleAccessRecord">
        <id property="id" column="id"/>
        <result property="plateNumber" column="plate_number"/>
        <result property="deviceId" column="device_id"/>
        <result property="eventType" column="event_type"/>
        <result property="eventMessage" column="event_message"/>
        <result property="captureTime" column="capture_time"/>
        <result property="photoUrl" column="photo_url"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 查询列表 -->
    <select id="searchByCondition" resultMap="BaseResultMap">
        SELECT *
        FROM new_vehicle_access_record
        WHERE 1=1
        <if test="deviceId != null and deviceId != ''">
          AND device_id = #{deviceId}
        </if>
        <if test="plateNumber != null and plateNumber != ''">
          AND plate_number LIKE CONCAT('%', #{plateNumber}, '%')
        </if>
        <if test="eventType != null and eventType != ''">
          AND event_type = #{eventType}
        </if>
        <if test="startTime != null">
          AND capture_time &gt;= #{startTime}
        </if>
        <if test="endTime != null">
          AND capture_time &lt;= #{endTime}
        </if>
        ORDER BY capture_time DESC
    </select>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.supervision.web.Hikvision.carDoor.web.entity.VehicleAccessRecord">
        INSERT INTO new_vehicle_access_record
            (device_id, plate_number, event_type, event_message, capture_time, photo_url, remark)
        VALUES
            (#{deviceId}, #{plateNumber}, #{eventType}, #{eventMessage}, #{captureTime}, #{photoUrl}, #{remark})
    </insert>

    <!-- 更新 -->
    <update id="update" parameterType="com.supervision.web.Hikvision.carDoor.web.entity.VehicleAccessRecord">
        UPDATE new_vehicle_access_record
        SET
            device_id=#{deviceId},
            plate_number=#{plateNumber},
            event_type=#{eventType},
            event_message = #{eventMessage},
            capture_time=#{captureTime},
            photo_url=#{photoUrl},
            remark=#{remark},
            update_time=NOW()
        WHERE id=#{id}
    </update>

    <!-- 删除单条 -->
    <delete id="deleteById" parameterType="long">
        DELETE FROM new_vehicle_access_record WHERE id=#{id}
    </delete>

    <!-- 批量删除 -->
    <delete id="batchDelete">
        DELETE FROM new_vehicle_access_record
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
