<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.supervision.web.Hikvision.peopleDoor.web.mapper.DeviceMapper">
    <!-- 结果映射 -->
    <resultMap id="DeviceResultMap" type="com.supervision.web.Hikvision.peopleDoor.web.entity.Device">
        <id property="id" column="id"/>
        <result property="serialNumber" column="serial_number"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
        <result property="accessPermission" column="access_permission"/>
        <result property="isUpdateStatus" column="is_update_status"/>
        <result property="location" column="location"/>
        <result property="ip" column="ip"/>
        <result property="port" column="port"/>
        <result property="account" column="account"/>
        <result property="password" column="password"/>
        <result property="isConnect" column="is_connect"/>
        <result property="status" column="status"/>
        <result property="firmwareVersion" column="firmware_version"/>
        <result property="doorsJson" column="doors_json"/>
        <result property="videosJson" column="videos_json"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="enable" column="enable"/>
    </resultMap>

    <!-- 按条件模糊查询 -->
    <select id="searchByCondition" resultMap="DeviceResultMap">
        SELECT *
        FROM new_device_info
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
            <if test="enable != null">
                AND enable = #{enable}
            </if>
        </where>
        ORDER BY id ASC
    </select>

    <!-- 查询所有设备名称 -->
    <select id="searchAllDeviceNames" resultType="com.supervision.web.Hikvision.peopleDoor.web.entity.Device">
        SELECT
            id,
            name
        FROM new_device_info
        ORDER BY name ASC
    </select>

    <!-- 根据ID查询设备 -->
    <select id="searchById" parameterType="long" resultMap="DeviceResultMap">
        SELECT *
        FROM new_device_info
        WHERE id = #{id}
    </select>

    <!-- 根据IP查询设备 -->
    <select id="searchByIp" parameterType="String" resultMap="DeviceResultMap">
        SELECT *
        FROM new_device_info
        WHERE ip = #{ip}
    </select>

    <!-- 插入设备 -->
    <insert id="insert" parameterType="com.supervision.web.Hikvision.peopleDoor.web.entity.Device" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO new_device_info (
            serial_number, name, type, access_permission, is_update_status, location, ip, port, account, password,
            is_connect, status, firmware_version, doors_json, videos_json, remark, create_time, update_time, enable
        )
        VALUES (
                   #{serialNumber}, #{name}, #{type}, #{accessPermission}, #{isUpdateStatus}, #{location}, #{ip}, #{port}, #{account}, #{password},
                   #{isConnect}, #{status}, #{firmwareVersion}, #{doorsJson}, #{videosJson}, #{remark}, #{createTime}, #{updateTime}, #{enable}
               )
    </insert>

    <!-- 更新设备 -->
    <update id="update" parameterType="com.supervision.web.Hikvision.peopleDoor.web.entity.Device">
        UPDATE new_device_info
        SET
            serial_number = #{serialNumber},
            name = #{name},
            type = #{type},
            access_permission = #{accessPermission},
            is_update_status = #{isUpdateStatus},
            location = #{location},
            ip = #{ip},
            port = #{port},
            account = #{account},
            password = #{password},
            is_connect = #{isConnect},
            status = #{status},
            firmware_version = #{firmwareVersion},
            doors_json = #{doorsJson},
            videos_json = #{videosJson},
            remark = #{remark},
            update_time = #{updateTime},
            enable = #{enable}
        WHERE id = #{id}
    </update>

    <!-- 删除设备 -->
    <delete id="delete" parameterType="long">
        DELETE FROM new_device_info WHERE id = #{id}
    </delete>

    <!-- 批量删除设备 -->
    <delete id="deleteBatch" parameterType="java.util.List">
        DELETE FROM new_device_info
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
