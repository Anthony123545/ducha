<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.supervision.grassrootsregistration.mapper.BdglWeekRecipeMapper">

    <resultMap type="BdglWeekRecipe" id="BdglWeekRecipeResult">
        <result property="id"    column="id"    />
        <result property="title"    column="title"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="messOfficer"    column="mess_officer"    />
        <result property="peopleId"    column="people_id"    />
        <result property="recipeContent"    column="recipe_content"    />
        <result property="unitId"    column="unit_id"    />
        <result property="leaderSign"    column="leader_sign"    />
        <result property="committeeSign"    column="committee_sign"    />
        <result property="messOfficerSign"    column="mess_officer_sign"    />
        <result property="createtime"    column="createtime"    />
        <result property="updatetime"    column="updatetime"    />
        <result property="messOfficerName"    column="mess_officer_name"    />
        <result property="peopleName"    column="people_name"    />
        <result property="unitName"    column="unit_name"    />
    </resultMap>

    <sql id="selectBdglWeekRecipeVo">
        select id, title, start_time, end_time, mess_officer, people_id, recipe_content, unit_id, leader_sign, committee_sign, mess_officer_sign, createtime, updatetime, mess_officer_name, people_name, unit_name from bdgl_week_recipe
    </sql>

    <select id="selectBdglWeekRecipeList" parameterType="BdglWeekRecipe" resultMap="BdglWeekRecipeResult">
        select id, title, start_time, end_time, mess_officer, people_id, recipe_content, unit_id, leader_sign, committee_sign, mess_officer_sign, createtime, updatetime, mess_officer_name, people_name, unit_name
        from bdgl_week_recipe c left join sys_dept t
        on c.unit_id=t.dept_id
        <where>
            <if test="unitId != null ">
                and (c.unit_id=#{unitId} or find_in_set(#{unitId}, t.ancestors))
            </if>
            <if test="title != null  and title != ''"> and c.title = #{title}</if>
            <if test="startTime != null "> and c.start_time = #{startTime}</if>
            <if test="endTime != null "> and c.end_time = #{endTime}</if>
            <if test="messOfficer != null "> and c.mess_officer = #{messOfficer}</if>
            <if test="peopleId != null "> and c.people_id = #{peopleId}</if>
            <if test="leaderSign != null  and leaderSign != ''"> and c.leader_sign like concat('%', #{leaderSign}, '%')</if>
            <if test="committeeSign != null  and committeeSign != ''"> and c.committee_sign like concat('%', #{committeeSign}, '%')</if>
            <if test="messOfficerSign != null  and messOfficerSign != ''"> and c.mess_officer_sign like concat('%', #{messOfficerSign}, '%')</if>
            <if test="unitName != null  and unitName != ''"> and c.unit_name like concat('%', #{unitName}, '%')</if>
        </where>
        order by end_time,c.id desc
    </select>

    <select id="selectBdglWeekRecipeById" parameterType="Integer" resultMap="BdglWeekRecipeResult">
        <include refid="selectBdglWeekRecipeVo"/>
        where id = #{id}
    </select>

    <insert id="insertBdglWeekRecipe" parameterType="BdglWeekRecipe" useGeneratedKeys="true" keyProperty="id">
        insert into bdgl_week_recipe
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null">title,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="messOfficer != null">mess_officer,</if>
            <if test="peopleId != null">people_id,</if>
            <if test="recipeContent != null">recipe_content,</if>
            <if test="unitId != null">unit_id,</if>
            <if test="leaderSign != null">leader_sign,</if>
            <if test="committeeSign != null">committee_sign,</if>
            <if test="messOfficerSign != null">mess_officer_sign,</if>
            <if test="createtime != null">createtime,</if>
            <if test="updatetime != null">updatetime,</if>
            <if test="messOfficerName != null">mess_officer_name,</if>
            <if test="peopleName != null">people_name,</if>
            <if test="unitName != null">unit_name,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null">#{title},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="messOfficer != null">#{messOfficer},</if>
            <if test="peopleId != null">#{peopleId},</if>
            <if test="recipeContent != null">#{recipeContent},</if>
            <if test="unitId != null">#{unitId},</if>
            <if test="leaderSign != null">#{leaderSign},</if>
            <if test="committeeSign != null">#{committeeSign},</if>
            <if test="messOfficerSign != null">#{messOfficerSign},</if>
            <if test="createtime != null">#{createtime},</if>
            <if test="updatetime != null">#{updatetime},</if>
            <if test="messOfficerName != null">#{messOfficerName},</if>
            <if test="peopleName != null">#{peopleName},</if>
            <if test="unitName != null">#{unitName},</if>
        </trim>
    </insert>

    <update id="updateBdglWeekRecipe" parameterType="BdglWeekRecipe">
        update bdgl_week_recipe
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null">title = #{title},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="messOfficer != null">mess_officer = #{messOfficer},</if>
            <if test="peopleId != null">people_id = #{peopleId},</if>
            <if test="recipeContent != null">recipe_content = #{recipeContent},</if>
            <if test="unitId != null">unit_id = #{unitId},</if>
            <if test="leaderSign != null">leader_sign = #{leaderSign},</if>
            <if test="committeeSign != null">committee_sign = #{committeeSign},</if>
            <if test="messOfficerSign != null">mess_officer_sign = #{messOfficerSign},</if>
            <if test="createtime != null">createtime = #{createtime},</if>
            <if test="updatetime != null">updatetime = #{updatetime},</if>
            <if test="messOfficerName != null">mess_officer_name = #{messOfficerName},</if>
            <if test="peopleName != null">people_name = #{peopleName},</if>
            <if test="unitName != null">unit_name = #{unitName},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteBdglWeekRecipeById" parameterType="Integer">
        delete from bdgl_week_recipe where id = #{id}
    </delete>

    <delete id="deleteBdglWeekRecipeByIds" parameterType="String">
        delete from bdgl_week_recipe where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
