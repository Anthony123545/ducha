            <if test="talkTheme != null  and talkTheme != ''"> and talk_theme = #{talkTheme}</if>
        </where>
        order by id desc
    </select>
    
    <select id="selectThoughtParliamentById" parameterType="Long" resultMap="ThoughtParliamentResult">
