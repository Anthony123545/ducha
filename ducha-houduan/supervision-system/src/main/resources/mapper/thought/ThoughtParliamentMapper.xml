    <sql id="selectThoughtParliamentVo">
        select id, unit_name, unit_id, start_time, end_time, create_time, update_time, create_name, create_id, file_path, file_name, talk_content, recorder, recorder_id, participants, participants_id, organizer, organizer_id, talk_theme from thought_parliament
