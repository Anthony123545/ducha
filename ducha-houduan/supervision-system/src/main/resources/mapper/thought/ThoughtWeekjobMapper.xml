            <if test="startTime != null "> and start_time = #{startTime}</if>
            <if test="endTime != null "> and end_time = #{endTime}</if>
        </where>
        order by id desc
    </select>
    
    <select id="selectThoughtWeekjobById" parameterType="Long" resultMap="ThoughtWeekjobResult">
        <include refid="selectThoughtWeekjobVo"/>
        where id = #{id}
