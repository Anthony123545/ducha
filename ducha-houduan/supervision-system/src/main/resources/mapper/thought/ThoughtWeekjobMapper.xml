    <sql id="selectThoughtWeekjobVo">
        select id, creat_time, update_time, creat_name, creat_id, remark, unit_name, unit_id, duty_leader, duty_leader_id, phone, military_officer, military_officer_id, political_officer, political_officer_id, job_title, start_time, end_time from thought_weekjob
