    <select id="selectThoughtWeekjobList" parameterType="ThoughtWeekjob" resultMap="ThoughtWeekjobResult">
        <include refid="selectThoughtWeekjobVo"/>
        <where>  
            <if test="creatTime != null "> and creat_time = #{creatTime}</if>
            <if test="creatName != null  and creatName != ''"> and creat_name like concat('%', #{creatName}, '%')</if>
            <if test="creatId != null "> and creat_id = #{creatId}</if>
            <if test="unitName != null  and unitName != ''"> and unit_name like concat('%', #{unitName}, '%')</if>
            <if test="unitId != null "> and unit_id = #{unitId}</if>
            <if test="dutyLeader != null  and dutyLeader != ''"> and duty_leader = #{dutyLeader}</if>
            <if test="dutyLeaderId != null "> and duty_leader_id = #{dutyLeaderId}</if>
            <if test="phone != null  and phone != ''"> and phone = #{phone}</if>
            <if test="militaryOfficer != null  and militaryOfficer != ''"> and military_officer = #{militaryOfficer}</if>
            <if test="militaryOfficerId != null  and militaryOfficerId != ''"> and military_officer_id = #{militaryOfficerId}</if>
            <if test="politicalOfficer != null  and politicalOfficer != ''"> and political_officer = #{politicalOfficer}</if>
            <if test="politicalOfficerId != null "> and Political_officer_id = #{politicalOfficerId}</if>
