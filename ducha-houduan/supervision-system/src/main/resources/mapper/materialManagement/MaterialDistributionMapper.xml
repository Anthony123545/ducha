            <if test="recipientId != null">recipient_id,</if>
            <if test="outPeopleId != null">out_people_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="barcode != null">#{barcode},</if>
