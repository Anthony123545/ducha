            <if test="recipientId != null">#{recipientId},</if>
            <if test="outPeopleId != null">#{outPeopleId},</if>
        </trim>
    </insert>

    <update id="updateMaterialDistribution" parameterType="MaterialDistribution">
        update material_distribution
        <trim prefix="SET" suffixOverrides=",">
            <if test="wuPinType != null">wu_pin_type = #{wuPinType},</if>
            <if test="name != null">name = #{name},</if>
            <if test="materialSpecification != null">material_specification = #{materialSpecification},</if>
            <if test="materialXh != null">material_xh = #{materialXh},</if>
