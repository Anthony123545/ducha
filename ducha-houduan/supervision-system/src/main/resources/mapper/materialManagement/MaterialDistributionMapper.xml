    </update>

    <delete id="deleteMaterialDistributionById" parameterType="Long">
        delete from material_distribution where id = #{id}
    </delete>

    <delete id="deleteMaterialDistributionByIds" parameterType="String">
        delete from material_distribution where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
