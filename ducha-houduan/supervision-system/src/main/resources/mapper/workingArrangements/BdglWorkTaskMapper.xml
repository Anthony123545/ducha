    <sql id="selectBdglWorkTaskVo">
        select id, name, people_id, number, type, start_time, end_time, file, file_name, remark, contents, admin_id, unit_id, unit_name, createtime, updatetime, people_name, unit_name2,task_progress,common,user_id,username from bdgl_work_task
    </sql>

    <select id="selectBdglWorkTaskList" parameterType="BdglWorkTask" resultMap="BdglWorkTaskResult">
        <include refid="selectBdglWorkTaskVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="peopleId != null  and peopleId != ''"> and people_id like concat('%', #{peopleId}, '%')</if>
            <if test="number != null  and number != ''"> and number = #{number}</if>
            <if test="type != null  and type != ''"> and type = #{type}</if>
            <if test="startTime !=null and endTime !=null" >
                and <![CDATA[
                    start_time>#{startTime} and end_time < #{endTime}
                ]]>
            </if>
<!--            <if test="startTime != null "> and start_time = #{startTime}</if>-->
<!--            <if test="endTime != null "> and end_time = #{endTime}</if>-->
            <if test="file != null  and file != ''"> and file = #{file}</if>
            <if test="fileName != null  and fileName != ''"> and file_name like concat('%', #{fileName}, '%')</if>
            <if test="contents != null  and contents != ''"> and contents = #{contents}</if>
            <if test="adminId != null "> and admin_id = #{adminId}</if>
            <if test="unitId != null "> and unit_id = #{unitId}</if>
            <if test="unitName != null  and unitName != ''"> and unit_name like concat('%', #{unitName}, '%')</if>
            <if test="createtime != null "> and createtime like concat('%', #{createtime}, '%')</if>
            <if test="updatetime != null "> and updatetime = #{updatetime}</if>
            <if test="peopleName != null  and peopleName != ''"> and people_name like concat('%', #{peopleName}, '%')</if>
            <if test="unitName2 != null  and unitName2 != ''"> and unit_name2 = #{unitName2}</if>
            <if test="taskProgress != null  and taskProgress != ''"> and task_progress = #{taskProgress}</if>
            <if test="common != null  and common != ''"> and common = #{common}</if>
            <if test="userId != null  "> and user_id = #{userId}</if>
            <if test="username != null  "> and username = #{username}</if>
        </where>
        order by createtime desc
    </select>
