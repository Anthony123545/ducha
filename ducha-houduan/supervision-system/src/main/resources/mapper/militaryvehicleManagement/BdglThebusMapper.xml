             <if test="idList!=null and idList.size()>0">
                and id in
                 <foreach collection="idList" item="id" open="(" separator="," close=")">
                     #{id}
                 </foreach>
             </if>
        </where>
        ORDER BY orders IS NULL, orders ASC,id DESC
