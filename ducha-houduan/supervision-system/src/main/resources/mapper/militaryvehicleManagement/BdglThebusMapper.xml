    <select id="selectVehicleModelList" resultType="java.util.Map">
        SELECT DISTINCT
            b.vehiclemodel AS dictValue,
            d.dict_label   AS dictLabel,
            b.vehiclenumber AS dictCode
        FROM bdgl_thebus b
                 LEFT JOIN sys_dict_data d
                           ON b.vehiclemodel = d.dict_value
                               AND d.dict_type = 'brand'
        WHERE b.vehiclemodel IS NOT NULL AND b.vehiclemodel != '' AND b.status = 1
        ORDER BY d.dict_label
    </select>

